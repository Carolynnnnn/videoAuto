# Pixelle Video AI Configuration Template
# Copy this file to .env and fill in your secrets.
# DO NOT commit the .env file to version control.

# --- Mode Selection ---
# PIXELLE_TEST_MODE: "1" for deterministic local test mode (no GPU/API required), "0" for production
# Local-Test: PIXELLE_TEST_MODE=1
# Production: PIXELLE_TEST_MODE=0
PIXELLE_TEST_MODE=1

# PIXELLE_BACKEND_MODE: 
# "direct" for Minimax-first vendor adapters (Minimax-First mode)
# "legacy" for provider path (Legacy-Provider mode)
PIXELLE_BACKEND_MODE=direct

# --- Provider Configuration (Required if PIXELLE_TEST_MODE=0) ---
PIXELLE_PROVIDER_URL=https://api.your-provider.com
PIXELLE_PROVIDER_API_KEY=your_provider_api_key_here

# --- Vendor Configuration (Minimax-first) ---
# Required if PIXELLE_BACKEND_MODE=direct and PIXELLE_TEST_MODE=0
MINIMAX_API_KEY=your_minimax_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com

# --- Operational Parameters ---
PIXELLE_CONCURRENCY_LIMIT=4
PIXELLE_PROVIDER_TIMEOUT=300.0
PIXELLE_PROVIDER_MAX_RETRIES=3
PIXELLE_PROVIDER_RETRY_BASE_DELAY=1.0

# --- Rollout Controls ---
PIXELLE_ROLLOUT_ENABLED=0
PIXELLE_ROLLOUT_PERCENTAGE=0

# --- Legacy / Extension Slots ---
# Add any additional provider-specific keys below
# CUSTOM_PROVIDER_SECRET=...
