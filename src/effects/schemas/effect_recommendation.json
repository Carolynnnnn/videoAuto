{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "segment_index": {
            "type": "integer",
            "minimum": 0,
            "description": "Zero-based index of the segment"
          },
          "sentiment": {
            "type": "string",
            "enum": ["positive", "negative", "neutral", "happy", "sad", "angry", "excited", "surprised", "love", "fear"],
            "description": "Detected sentiment of the segment"
          },
          "effect_type": {
            "type": "string",
            "enum": ["joyful", "calming", "subtle"],
            "description": "Recommended visual effect type"
          },
          "reason": {
            "type": "string",
            "description": "Brief explanation for the recommendation"
          },
          "asset_hint": {
            "type": "string",
            "description": "Optional keyword hint for asset selection"
          }
        },
        "required": ["segment_index", "sentiment", "effect_type"]
      }
    }
  },
  "required": ["recommendations"]
}
